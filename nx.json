{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "useDaemonProcess": false,
  "targetDefaults": {
    "build": {
      "cache": false,
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "production",
        "^production"
      ]
    },
    "build-min": {
      "cache": false
    },
    "serve": {
      "cache": false
    },
    "extract-i18n": {
      "cache": false
    },
    "test": {
      "cache": false,
      "inputs": [
        "default",
        "^production"
      ]
    },
    "test-prod": {
      "cache": false
    }
  },
  "namedInputs": {
    "sharedGlobals": [],
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default"
    ]
  },
  "analytics": true
}