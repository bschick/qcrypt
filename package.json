{
  "name": "@qcrypt/monorepo",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "serve": "nx serve web --hmr false --host 0.0.0.0 --watch --poll 1000 --ssl --ssl-cert apps/web/localssl/localhost.crt --ssl-key apps/web/localssl/localhost.key",
    "test": "pnpm test:web && pnpm test:server && pnpm test:libs && pnpm test:cli",
    "build:web": "NG_BUILD_OPTIMIZE_CHUNKS=1 nx build web --configuration test --output-path \"${QC_WEB_OUT:-dist/web-test}\" --subresource-integrity && node apps/web/scripts/validate-build.mjs \"${QC_WEB_OUT:-dist/web-test}/browser\"",
    "build:web:prod": "NG_BUILD_OPTIMIZE_CHUNKS=1 nx build web --configuration production --output-path \"${QC_WEB_OUT:-dist/web}\" --subresource-integrity && node apps/web/scripts/validate-build.mjs \"${QC_WEB_OUT:-dist/web}/browser\"",
    "deploy:web": "apps/web/scripts/deploy.sh",
    "deploy:web:prod": "apps/web/scripts/deploy.sh --prod prod",
    "rollback:web": "apps/web/scripts/deploy.sh rollback",
    "rollback:web:prod": "apps/web/scripts/deploy.sh --prod prod rollback",
    "test:web": "nx test web",
    "test:web:watch": "nx test web --watch",
    "test:web:most": "nx test web --runnerConfig=apps/web/vitest-most.config.ts",
    "test:web:all": "nx test web --runnerConfig=apps/web/vitest-all.config.ts",
    "test:libs": "pnpm test:libs:crypto && pnpm test:libs:api",
    "test:libs:crypto": "nx test crypto",
    "test:libs:api": "nx test api",
    "test:e2e": "bash apps/web/scripts/run_e2e.sh --project local",
    "test:fuzz": "QC_FULL_FUZZ=true pnpm exec vitest run --config apps/server/vitest.config.ts apps/server/spec/fuzz.spec.ts",
    "test:e2e:prod": "bash apps/web/scripts/run_e2e.sh --project prod",
    "test:fuzz:prod": "QC_ENV=prod QC_FULL_FUZZ=true pnpm exec vitest run --config apps/server/vitest.config.ts apps/server/spec/fuzz.spec.ts",
    "build:cli": "nx build cli",
    "build:cli:min": "nx build-min cli",
    "build:libs:crux": "node libs/crypto/crux/regen.mjs",
    "test:cli": "nx test cli",
    "vectors:ciphers": "TSX_TSCONFIG_PATH=apps/web/scripts/tsconfig.json tsx apps/web/scripts/gen_ciphers_vectors.ts",
    "vectors:ciphersvc": "TSX_TSCONFIG_PATH=apps/web/scripts/tsconfig.json tsx apps/web/scripts/gen_ciphersvc_vectors.ts",
    "vectors:keys": "TSX_TSCONFIG_PATH=apps/web/scripts/tsconfig.json tsx apps/web/scripts/gen_keys_vectors.ts",
    "build:server": "nx build server",
    "build:server:min": "nx build-min server",
    "deploy:server": "apps/server/scripts/deploy.sh",
    "deploy:server:prod": "apps/server/scripts/deploy.sh --prod prod",
    "rollback:server:prod": "apps/server/scripts/deploy.sh --prod prod rollback",
    "test:server": "nx test server",
    "test:server:prod": "nx test-prod server",
    "test:timing": "nx test-timing server",
    "test:timing:prod": "nx test-timing-prod server",
    "svgo:flow": "bash apps/web/scripts/svgo_flow.sh"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.16",
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.16",
    "@angular/compiler": "^21.2.16",
    "@angular/core": "^21.2.16",
    "@angular/forms": "^21.2.16",
    "@angular/material": "^21.2.14",
    "@angular/platform-browser": "^21.2.16",
    "@angular/router": "^21.2.16",
    "@aws-sdk/client-dynamodb": "^3.1063.0",
    "@aws-sdk/client-kms": "^3.1063.0",
    "@inquirer/core": "^11.2.1",
    "@inquirer/prompts": "^8.5.2",
    "@scure/bip39": "^2.2.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "@zxcvbn-ts/language-es-es": "^3.0.2",
    "@zxcvbn-ts/matcher-pwned": "^3.0.4",
    "dompurify": "^3.4.8",
    "electrodb": "^3.9.0",
    "jsonwebtoken": "^9.0.3",
    "libsodium-wrappers": "^0.8.4",
    "reopen-tty": "^1.1.2",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "xss": "^1.0.15",
    "yargs": "^18.0.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/core": "^21.2.14",
    "@angular-devkit/schematics": "^21.2.14",
    "@angular/build": "^21.2.14",
    "@angular/cli": "^21.2.14",
    "@angular/compiler-cli": "^21.2.16",
    "@aws-sdk/types": "^3.973.11",
    "@nx/angular": "^22.7.5",
    "@nx/workspace": "^22.7.5",
    "@playwright/test": "^1.60.0",
    "@schematics/angular": "^21.2.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.2",
    "@types/yargs": "^17.0.35",
    "@vitest/browser-playwright": "^4.1.8",
    "devtools-protocol": "^0.0.1642743",
    "esbuild": "^0.28.0",
    "nid-webauthn-emulator": "^0.2.13",
    "nx": "^22.7.5",
    "svgo": "^4.0.1",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
