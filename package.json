{
  "name": "@qcrypt/monorepo",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "serve": "nx serve web --hmr false --host 0.0.0.0 --watch --poll 1000 --ssl --ssl-cert apps/web/localssl/localhost.crt --ssl-key apps/web/localssl/localhost.key",
    "test": "pnpm test:web && pnpm test:server && pnpm test:lib && pnpm test:cli",
    "build:web": "nx build web --configuration production --subresource-integrity",
    "test:web": "nx test web",
    "test:web:watch": "nx test web --watch",
    "test:web:all": "nx test web --runnerConfig=apps/web/vitest-all.config.ts",
    "test:lib": "pnpm test:lib:crypto",
    "test:lib:crypto": "nx test crypto",
    "test:e2e": "NODE_EXTRA_CA_CERTS=./apps/web/localssl/qcrypt.pem pnpm exec playwright test --config apps/web/playwright.config.ts --project=local --workers=1 apps/web/tests/sequential && pnpm exec playwright test --config apps/web/playwright.config.ts --project=local apps/web/tests/parallel --grep-invert \"/@fullfuzz/\"",
    "test:fuzz": "NODE_EXTRA_CA_CERTS=./apps/web/localssl/qcrypt.pem pnpm exec playwright test --config apps/web/playwright.config.ts --project=local apps/web/tests/parallel --grep \"/@fullfuzz/\"",
    "test:e2e:prod": "pnpm exec playwright test --config apps/web/playwright.config.ts --project=prod --workers=1 apps/web/tests/sequential && pnpm exec playwright test --config apps/web/playwright.config.ts --project=prod apps/web/tests/parallel --grep-invert \"/@fullfuzz/\"",
    "test:fuzz:prod": "pnpm exec playwright test --config apps/web/playwright.config.ts --project=prod apps/web/tests/parallel --grep \"/@fullfuzz/\"",
    "build:cli": "nx build cli",
    "build:cli:min": "nx build-min cli",
    "test:cli": "nx test cli",
    "build:server": "nx build server",
    "build:server:min": "nx build-min server",
    "test:server": "nx test server",
    "test:server:prod": "nx test-prod server",
    "test:server:timing": "nx test-timing server",
    "test:server:timing:prod": "nx test-timing-prod server"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.9",
    "@angular/cdk": "^21.2.7",
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/material": "^21.2.7",
    "@angular/platform-browser": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@aws-sdk/client-dynamodb": "^3.1033.0",
    "@aws-sdk/client-kms": "^3.1033.0",
    "@inquirer/core": "^11.1.9",
    "@inquirer/prompts": "^8.4.2",
    "@scure/bip39": "^2.0.1",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "@zxcvbn-ts/language-es-es": "^3.0.2",
    "@zxcvbn-ts/matcher-pwned": "^3.0.4",
    "electrodb": "^3.7.5",
    "jsonwebtoken": "^9.0.3",
    "libsodium-wrappers": "^0.8.4",
    "luxon": "^3.7.2",
    "reopen-tty": "^1.1.2",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "xss": "^1.0.15",
    "yargs": "^18.0.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "^21.2.7",
    "@angular-devkit/schematics": "^21.2.7",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.9",
    "@aws-sdk/types": "^3.973.8",
    "@nx/angular": "^22.6.5",
    "@nx/workspace": "^22.6.5",
    "@playwright/test": "^1.59.1",
    "@schematics/angular": "^21.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "@types/yargs": "^17.0.35",
    "@vitest/browser-playwright": "^4.1.4",
    "devtools-protocol": "^0.0.1617013",
    "esbuild": "^0.28.0",
    "nid-webauthn-emulator": "^0.2.11",
    "nx": "^22.6.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "picomatch": ">=4.0.4",
      "@angular/platform-server" : ">=21.2.9"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@module-federation/enhanced": "2.1.0"
      }
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "less",
      "lmdb",
      "msgpackr-extract",
      "nx"
    ]
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
