{
  "name": "@qcrypt/monorepo",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "serve": "nx serve web --hmr false --host 0.0.0.0 --watch --poll 1000 --ssl --ssl-cert apps/web/localssl/localhost.crt --ssl-key apps/web/localssl/localhost.key",
    "test": "pnpm test:web && pnpm test:server && pnpm test:libs && pnpm test:cli",
    "build:web": "NG_BUILD_OPTIMIZE_CHUNKS=1 nx build web --configuration production --subresource-integrity && node apps/web/scripts/postbuild-preload-check.mjs",
    "deploy:web": "apps/web/scripts/deploy.sh",
    "deploy:web:prod": "apps/web/scripts/deploy.sh --prod prod",
    "rollback:web": "apps/web/scripts/deploy.sh rollback",
    "rollback:web:prod": "apps/web/scripts/deploy.sh --prod prod rollback",
    "test:web": "nx test web",
    "test:web:watch": "nx test web --watch",
    "test:web:all": "nx test web --runnerConfig=apps/web/vitest-all.config.ts",
    "test:libs": "pnpm test:libs:crypto",
    "test:libs:crypto": "nx test crypto",
    "test:e2e": "bash apps/web/scripts/run_e2e.sh --project local",
    "test:fuzz": "NODE_EXTRA_CA_CERTS=./apps/web/localssl/qcrypt.pem pnpm exec playwright test --config apps/web/playwright.config.ts --project=local apps/web/tests/parallel --grep \"/@fullfuzz/\"",
    "test:e2e:prod": "bash apps/web/scripts/run_e2e.sh --project prod",
    "test:fuzz:prod": "pnpm exec playwright test --config apps/web/playwright.config.ts --project=prod apps/web/tests/parallel --grep \"/@fullfuzz/\"",
    "build:cli": "nx build cli",
    "build:cli:min": "nx build-min cli",
    "test:cli": "nx test cli",
    "vectors:ciphers": "TSX_TSCONFIG_PATH=apps/web/scripts/tsconfig.json tsx apps/web/scripts/gen_ciphers_vectors.ts",
    "vectors:ciphersvc": "TSX_TSCONFIG_PATH=apps/web/scripts/tsconfig.json tsx apps/web/scripts/gen_ciphersvc_vectors.ts",
    "vectors:keys": "TSX_TSCONFIG_PATH=apps/web/scripts/tsconfig.json tsx apps/web/scripts/gen_keys_vectors.ts",
    "build:server": "nx build server",
    "build:server:min": "nx build-min server",
    "deploy:server": "apps/server/scripts/deploy.sh",
    "deploy:server:prod": "apps/server/scripts/deploy.sh --prod prod",
    "rollback:server:prod": "apps/server/scripts/deploy.sh --prod prod rollback",
    "test:server": "nx test server",
    "test:server:prod": "nx test-prod server",
    "test:timing": "nx test-timing server",
    "test:timing:prod": "nx test-timing-prod server"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.12",
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/material": "^21.2.10",
    "@angular/platform-browser": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@aws-sdk/client-dynamodb": "^3.1045.0",
    "@aws-sdk/client-kms": "^3.1045.0",
    "@inquirer/core": "^11.1.10",
    "@inquirer/prompts": "^8.4.3",
    "@scure/bip39": "^2.2.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "@zxcvbn-ts/language-es-es": "^3.0.2",
    "@zxcvbn-ts/matcher-pwned": "^3.0.4",
    "electrodb": "^3.7.5",
    "jsonwebtoken": "^9.0.3",
    "libsodium-wrappers": "^0.8.4",
    "reopen-tty": "^1.1.2",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "xss": "^1.0.15",
    "yargs": "^18.0.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/core": "^21.2.10",
    "@angular-devkit/schematics": "^21.2.10",
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@aws-sdk/types": "^3.973.8",
    "@nx/angular": "^22.7.1",
    "@nx/workspace": "^22.7.1",
    "@playwright/test": "^1.59.1",
    "@schematics/angular": "^21.2.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.2",
    "@types/yargs": "^17.0.35",
    "@vitest/browser-playwright": "^4.1.5",
    "devtools-protocol": "^0.0.1628107",
    "esbuild": "^0.28.0",
    "nid-webauthn-emulator": "^0.2.11",
    "nx": "^22.7.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "picomatch": ">=4.0.4",
      "@angular/platform-server": ">=21.2.9",
      "fast-xml-parser": ">=5.7.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@module-federation/enhanced": "2.1.0"
      }
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "less",
      "lmdb",
      "msgpackr-extract",
      "nx"
    ]
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
