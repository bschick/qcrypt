{
  "name": "cli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/cli/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node apps/cli/build.js",
        "cwd": "{workspaceRoot}"
      },
      "outputs": ["{workspaceRoot}/dist/cli/qcrypt.cjs"]
    },
    "build-min": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node apps/cli/build.js",
        "cwd": "{workspaceRoot}"
      },
      "outputs": ["{workspaceRoot}/dist/cli/qcrypt.cjs"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec vitest run --config apps/cli/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
